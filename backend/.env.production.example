# ── Datenbank (Supabase) ──────────────────────────────────────────────────────
# Connection-String aus Supabase → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.gbcxekmeeyybxzoynles.supabase.co:5432/postgres

# ── Groq KI ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_ENABLED=true

# ── Ollama deaktivieren ───────────────────────────────────────────────────────
OLLAMA_ENABLED=false

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
# URL des Angular-Frontends (Vercel oder Railway)
FRONTEND_URL=https://werkstatt.cargokoehler.de

# ── PDF-Watchfolder (kein lokaler Pfad in Produktion) ─────────────────────────
# PDF-Upload erfolgt über HTTP POST /invoices/upload
WATCH_FOLDER=/tmp/rechnungen
