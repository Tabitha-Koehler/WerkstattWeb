{
  "name": "werkstattweb-frontend",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "postcss src/styles.css -o src/styles-compiled.css && ng serve --host 0.0.0.0 --proxy-config proxy.conf.json",
    "build": "postcss src/styles.css -o src/styles-compiled.css && ng build",
    "watch": "ng build --watch --configuration development"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@fortawesome/fontawesome-free": "^6.7.0",
    "@primeng/themes": "^19.0.0",
    "ng2-pdf-viewer": "^10.0.0",
    "primeng": "^19.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "postcss": "^8.5.0",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.0"
  }
}
